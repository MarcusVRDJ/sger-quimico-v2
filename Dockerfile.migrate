# Migration container that runs migrations and can optionally seed the database
FROM node:22-alpine

RUN apk add --no-cache libc6-compat

WORKDIR /app

COPY package.json package-lock.json ./
RUN npm ci

COPY . .

# Run migrations and optionally seed (RUN_SEED=false to skip)
CMD ["sh", "-c", "npm run db:migrate && if [ \"${RUN_SEED:-true}\" = \"true\" ]; then npm run db:seed; else echo 'Skipping seed (RUN_SEED=false)'; fi"]
