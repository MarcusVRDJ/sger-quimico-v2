# ── Local development ─────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/sge_quimico_v2

# ── Docker Compose (use this when running via docker compose up) ──────────────
# DATABASE_URL is assembled automatically from POSTGRES_* variables.
# Override these if you want non-default credentials:
# POSTGRES_USER=sge
# POSTGRES_PASSWORD=sge
# POSTGRES_DB=sge_quimico_v2

# ── Required ─────────────────────────────────────────────────────────────────
# Must be set to a secure random string (minimum 32 characters).
# Generate one with: openssl rand -base64 32
JWT_SECRET=sua-chave-secreta-aqui-minimo-32-caracteres

# ── Email (Resend) ────────────────────────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxx
RESEND_FROM_EMAIL=noreply@.com
ADMIN_EMAIL=admin@sge.com

# ── App URL ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Server Actions (Deploy) ───────────────────────────────────────────────────
# Comma-separated list of allowed origins (host[:port] without protocol)
# Example: app.seudominio.com,admin.seudominio.com
NEXT_SERVER_ACTIONS_ALLOWED_ORIGINS=localhost:3000

# ── Migration behavior (Docker) ───────────────────────────────────────────────
# Set to false in production if you do not want automatic seed on startup
RUN_SEED=true
